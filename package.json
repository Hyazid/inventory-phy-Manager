{
  "name": "inventaire-physique",
  "version": "1.0.0",
  "description": "Application de gestion d'inventaire physique",
  "author": {
    "name": "Hyazid",
    "email": "yazid.hanniche.me@gmail.com"
  },
  "main": "src/main/index.js",
  "scripts": {
    "dev":         "concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "build":       "vite build && electron-builder",
    "build:linux": "vite build && electron-builder --linux",
    "build:win":   "vite build && electron-builder --win",
    "build:mac":   "vite build && electron-builder --mac",
    "start":       "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "bwip-js":        "^4.8.0",
    "pdfkit":         "^0.15.0",
    "xlsx":           "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild":   "^3.7.2",
    "@vitejs/plugin-react":"^4.7.0",
    "concurrently":        "^8.2.2",
    "electron":            "^29.4.6",
    "electron-builder":    "^24.13.3",
    "react":               "^18.3.1",
    "react-dom":           "^18.3.1",
    "react-router-dom":    "^6.30.3",
    "vite":                "^5.4.21",
    "wait-on":             "^9.0.4"
  },
  "build": {
    "appId":       "com.societe.inventaire",
    "productName": "Inventaire Physique",
    "asar":        true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bwip-js/**"
    ],
    "files": [
      "dist/**",
      "src/main/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": [{
        "target": "nsis",
        "arch":   ["x64"]
      }]
    },
    "nsis": {
      "oneClick":                          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":             true,
      "createStartMenuShortcut":           true
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ]
    },
    "directories": {
      "output": "release"
    }
  }
}