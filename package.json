{
  "name": "inventaire-physique",
  "version": "1.0.0",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:linux":  "vite build && electron-builder --linux",
    "build:win":    "vite build && electron-builder --win",
    "build:mac":    "vite build && electron-builder --mac",
    "lint": "eslint src/",
    "start": "electron ."
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "bwip-js": "^4.8.0",
    "jsbarcode": "^3.12.3",
    "pdfkit": "^0.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^3.4.1",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.societe.inventaire",
    "productName": "Inventaire Physique",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "dist/**",
      "src/main/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "src/main/db/schema.sql",
        "to": "schema.sql"
      }
    ]
  }
}
